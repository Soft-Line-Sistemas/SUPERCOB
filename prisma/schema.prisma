generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   String                @id @default(cuid())
  nome                 String
  email                String                @unique
  senha                String
  role                 String                @default("GERENTE") @db.VarChar(20)
  avatarUrl            String?
  isActive             Boolean               @default(true)
  canManageUsers       Boolean               @default(false)
  canManageClients     Boolean               @default(true)
  canManageLoans       Boolean               @default(true)
  createdAt            DateTime              @default(now())
  auditoriasGeradas    AuditoriaGeral[]      @relation("AuditoriaAutor")
  emprestimos          Emprestimo[]
  emprestimoHistoricos EmprestimoHistorico[] @relation("EmprestimoHistoricoCreatedBy")
  mensagensRecebidas   MensagemInterna[]     @relation("MensagensRecebidas")
  mensagensEnviadas    MensagemInterna[]     @relation("MensagensEnviadas")
  passwordResetTokens  PasswordResetToken[]
  clientesArquivadosPor       ClienteArquivado[]             @relation("ClienteArquivadoPor")
  emprestimosArquivados       EmprestimoArquivado[]          @relation("EmprestimoArquivadoUsuario")
  emprestimosArquivadosPor    EmprestimoArquivado[]          @relation("EmprestimoArquivadoPor")
  historicosArquivadosCriados EmprestimoHistoricoArquivado[] @relation("EmprestimoHistoricoArquivadoCreatedBy")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      Usuario   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MensagemInterna {
  id             String   @id @default(cuid())
  conteudo       String   @db.Text
  isLida         Boolean  @default(false)
  isMassiva      Boolean  @default(false)
  remetenteId    String
  destinatarioId String?
  createdAt      DateTime @default(now())
  destinatario   Usuario? @relation("MensagensRecebidas", fields: [destinatarioId], references: [id], onUpdate: NoAction)
  remetente      Usuario  @relation("MensagensEnviadas", fields: [remetenteId], references: [id], onUpdate: NoAction)

  @@index([destinatarioId])
  @@index([remetenteId])
  @@index([createdAt])
  @@index([isLida])
}

model Cliente {
  id                 String             @id @default(cuid())
  nome               String
  indicacao          String?
  cpf                String?
  rg                 String?
  orgao              String?
  diaNasc            Int?
  mesNasc            Int?
  anoNasc            Int?
  email              String?
  whatsapp           String?
  instagram          String?
  cep                String?
  endereco           String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  pontoReferencia    String?
  profissao          String?
  empresa            String?
  cepEmpresa         String?
  enderecoEmpresa    String?
  cidadeEmpresa      String?
  estadoEmpresa      String?
  contatoEmergencia1 String?
  contatoEmergencia2 String?
  contatoEmergencia3 String?
  telefone2          String?
  observacoes        String?            @db.Text
  cep2               String?
  endereco2          String?
  numeroEndereco2    Int?
  complemento2       String?
  bairro2            String?
  cidade2            String?
  estado2            String?
  pontoReferencia2   String?
  createdAt          DateTime           @default(now())
  numeroEndereco     Int?
  documentos         ClienteDocumento[]
  loans              Emprestimo[]
  whatsappPrefs      WhatsappAutomationClientPreference[]
}

model Emprestimo {
  id                  String                @id @default(cuid())
  clienteId           String
  usuarioId           String?
  valor               Float
  quantidadeParcelas  Int?
  jurosMes            Float                 @default(0)
  jurosAtrasoDia      Float                 @default(0)
  vencimento          DateTime?
  quitadoEm           DateTime?
  status              String                @default("ABERTO") @db.VarChar(20)
  observacao          String?               @db.Text
  arquivo1            String?
  arquivo2            String?
  arquivo3            String?
  arquivo4            String?
  arquivo5            String?
  createdAt           DateTime              @default(now())
  valorPago           Float                 @default(0)
  jurosPagos          Float                 @default(0)
  cobrancaAtiva       Boolean               @default(false)
  inadimplente        Boolean               @default(false)
  lastInterestAccrual DateTime?
  cliente             Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario             Usuario?              @relation(fields: [usuarioId], references: [id])
  historico           EmprestimoHistorico[]
  whatsappDispatches  WhatsappAutomationDispatch[]

  @@index([status])
  @@index([createdAt])
  @@index([usuarioId])
  @@index([clienteId])
  @@index([vencimento])
}

model WhatsappAutomationConfig {
  id                   String                    @id @default(cuid())
  enabled              Boolean                   @default(true)
  defaultCountryCode   String                    @default("55") @db.VarChar(5)
  timezone             String                    @default("America/Bahia") @db.VarChar(60)
  quietHoursStart      String?                   @db.VarChar(5)
  quietHoursEnd        String?                   @db.VarChar(5)
  sendOnWeekends       Boolean                   @default(false)
  minIntervalMinutes   Int                       @default(240)
  queueGapMinutes      Int                       @default(0)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  rules                WhatsappAutomationRule[]
}

model WhatsappAutomationRule {
  id             String                   @id @default(cuid())
  configId       String
  key            String                   @unique @db.VarChar(50)
  title          String                   @db.VarChar(80)
  enabled        Boolean                  @default(true)
  priority       Int                      @default(100)
  triggerType    String                   @db.VarChar(20)
  offsetDays     Int                      @default(0)
  recurrenceDays Int?
  sendTime       String                   @default("09:00") @db.VarChar(5)
  template       String                   @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  config         WhatsappAutomationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  dispatches     WhatsappAutomationDispatch[]
  dispatchesArquivados WhatsappAutomationDispatchArquivado[] @relation("WhatsappAutomationDispatchArquivadoRule")

  @@index([configId])
  @@index([enabled, priority])
}

model WhatsappAutomationClientPreference {
  id              String   @id @default(cuid())
  clienteId       String   @unique
  enabled         Boolean  @default(true)
  pausedAt        DateTime?
  pauseReason     String?  @db.VarChar(120)
  allowRecurrence Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cliente         Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model WhatsappAutomationDispatch {
  id             String                @id @default(cuid())
  ruleId         String
  emprestimoId   String
  status         String                @default("PENDING") @db.VarChar(20)
  scheduledFor   DateTime?
  attemptedAt    DateTime?
  sentAt         DateTime?
  errorMessage   String?               @db.Text
  payloadPreview String?               @db.Text
  providerRef    String?               @db.VarChar(120)
  triggerMode    String                @default("MANUAL") @db.VarChar(20)
  requiresManualFollowUp Boolean       @default(false)
  followUpStatus String                @default("NONE") @db.VarChar(20)
  followUpResolvedAt DateTime?
  followUpNotes  String?               @db.Text
  createdAt      DateTime              @default(now())
  rule           WhatsappAutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  emprestimo     Emprestimo            @relation(fields: [emprestimoId], references: [id], onDelete: Cascade)

  @@index([ruleId, status])
  @@index([emprestimoId, createdAt])
  @@index([scheduledFor])
}

model EmprestimoHistorico {
  id           String     @id @default(cuid())
  emprestimoId String
  descricao    String     @db.Text
  createdAt    DateTime   @default(now())
  createdById  String?
  tipo         String?    @db.VarChar(20)
  createdBy    Usuario?   @relation("EmprestimoHistoricoCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  emprestimo   Emprestimo @relation(fields: [emprestimoId], references: [id], onDelete: Cascade)

  @@index([emprestimoId])
  @@index([tipo])
  @@index([createdAt])
}

model ClienteDocumento {
  id           String   @id @default(cuid())
  clienteId    String
  originalName String
  fileName     String   @unique
  mimeType     String   @db.VarChar(100)
  size         Int
  createdAt    DateTime @default(now())
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model AuditoriaGeral {
  id         String   @id @default(cuid())
  autorId    String?
  entidade   String   @db.VarChar(50)
  entidadeId String   @db.VarChar(50)
  acao       String   @db.VarChar(50)
  detalhes   String?  @db.Text
  antes      String?  @db.Text
  depois     String?  @db.Text
  createdAt  DateTime @default(now())
  autor      Usuario? @relation("AuditoriaAutor", fields: [autorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ClienteArquivado {
  id                 String   @id
  nome               String
  indicacao          String?
  cpf                String?
  rg                 String?
  orgao              String?
  diaNasc            Int?
  mesNasc            Int?
  anoNasc            Int?
  email              String?
  whatsapp           String?
  instagram          String?
  cep                String?
  endereco           String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  pontoReferencia    String?
  profissao          String?
  empresa            String?
  cepEmpresa         String?
  enderecoEmpresa    String?
  cidadeEmpresa      String?
  estadoEmpresa      String?
  contatoEmergencia1 String?
  contatoEmergencia2 String?
  contatoEmergencia3 String?
  telefone2          String?
  observacoes        String?  @db.Text
  cep2               String?
  endereco2          String?
  numeroEndereco2    Int?
  complemento2       String?
  bairro2            String?
  cidade2            String?
  estado2            String?
  pontoReferencia2   String?
  numeroEndereco     Int?
  createdAt          DateTime

  arquivadoEm        DateTime @default(now())
  arquivadoPorId     String?
  motivoArquivamento String?  @db.Text

  arquivadoPor       Usuario? @relation("ClienteArquivadoPor", fields: [arquivadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documentos         ClienteDocumentoArquivado[]
  whatsappPrefs      WhatsappAutomationClientPreferenceArquivado?

  @@index([arquivadoEm])
  @@index([cpf])
}

model EmprestimoArquivado {
  id                     String    @id
  clienteId              String
  usuarioId              String?
  valor                  Float
  quantidadeParcelas     Int?
  jurosMes               Float
  jurosAtrasoDia         Float
  vencimento             DateTime?
  quitadoEm              DateTime?
  status                 String    @db.VarChar(20)
  observacao             String?   @db.Text
  arquivo1               String?
  arquivo2               String?
  arquivo3               String?
  arquivo4               String?
  arquivo5               String?
  createdAt              DateTime
  valorPago              Float
  jurosPagos             Float
  cobrancaAtiva          Boolean
  inadimplente            Boolean
  lastInterestAccrual    DateTime?

  arquivadoEm            DateTime @default(now())
  arquivadoPorId         String?
  motivoArquivamento     String?  @db.Text
  clienteTambemArquivado Boolean  @default(false)

  usuario                Usuario?  @relation("EmprestimoArquivadoUsuario", fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  arquivadoPor           Usuario?  @relation("EmprestimoArquivadoPor", fields: [arquivadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  historico              EmprestimoHistoricoArquivado[]
  whatsappDispatches     WhatsappAutomationDispatchArquivado[]

  @@index([clienteId])
  @@index([arquivadoEm])
  @@index([status])
}

model WhatsappAutomationClientPreferenceArquivado {
  id              String    @id
  clienteId       String    @unique
  enabled         Boolean
  pausedAt        DateTime?
  pauseReason     String?   @db.VarChar(120)
  allowRecurrence Boolean
  createdAt       DateTime
  updatedAt       DateTime

  arquivadoEm     DateTime  @default(now())

  clienteArquivado ClienteArquivado @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model WhatsappAutomationDispatchArquivado {
  id                     String    @id
  ruleId                 String
  emprestimoId           String
  status                 String    @db.VarChar(20)
  scheduledFor           DateTime?
  attemptedAt            DateTime?
  sentAt                 DateTime?
  errorMessage           String?   @db.Text
  payloadPreview         String?   @db.Text
  providerRef            String?   @db.VarChar(120)
  triggerMode            String    @db.VarChar(20)
  requiresManualFollowUp Boolean
  followUpStatus         String    @db.VarChar(20)
  followUpResolvedAt     DateTime?
  followUpNotes          String?   @db.Text
  createdAt              DateTime

  arquivadoEm            DateTime  @default(now())

  rule                   WhatsappAutomationRule @relation("WhatsappAutomationDispatchArquivadoRule", fields: [ruleId], references: [id], onDelete: Cascade)
  emprestimoArquivado    EmprestimoArquivado    @relation(fields: [emprestimoId], references: [id], onDelete: Cascade)

  @@index([emprestimoId])
  @@index([ruleId, status])
}

model EmprestimoHistoricoArquivado {
  id                  String   @id
  emprestimoId        String
  descricao           String   @db.Text
  createdAt           DateTime
  createdById         String?
  tipo                String?  @db.VarChar(20)

  arquivadoEm         DateTime @default(now())

  createdBy           Usuario?            @relation("EmprestimoHistoricoArquivadoCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  emprestimoArquivado EmprestimoArquivado @relation(fields: [emprestimoId], references: [id], onDelete: Cascade)

  @@index([emprestimoId])
}

model ClienteDocumentoArquivado {
  id           String   @id
  clienteId    String
  originalName String
  fileName     String   @unique
  mimeType     String   @db.VarChar(100)
  size         Int
  createdAt    DateTime

  arquivadoEm  DateTime @default(now())

  clienteArquivado ClienteArquivado @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}
